# 所有变量都是可选的，不设也能跑。

# 仅用于公开站点 SEO（sitemap、canonical、JSON-LD）
# 不设：sitemap 为空、canonical 走相对路径、JSON-LD 不输出
# 仅当你把这个项目作为公开站点对外部署时才需要设置
# NEXT_PUBLIC_WEB_URL=https://your-domain.com

# 高德地图 JS API（不设地图 / 城市搜索功能优雅降级，其他功能正常）
# NEXT_PUBLIC_AMAP_KEY=your-amap-key
# NEXT_PUBLIC_AMAP_SECURITY_CODE=your-amap-security-code

# 默认主题 light / dark（默认 light）
# NEXT_PUBLIC_DEFAULT_THEME=light

# 是否按浏览器语言自动切换 zh / en（默认 false）
# NEXT_PUBLIC_LOCALE_DETECTION=false
